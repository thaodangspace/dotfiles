theme = "Solarized Dark Patched"

background-opacity = 0.9
background-blur-radius = 20
background = #031219

font-family = "IBM Plex Mono Text"
font-family-bold = "IBM Plex Mono Bold"
font-size = 16
adjust-cell-height = 10%

# Show the title bar and tabs on macOS
macos-titlebar-style = tabs
window-theme = ghostty
window-title-font-family = "IBM Plex Mono Text"

# Window size - always open with consistent dimensions
# Size is in terminal grid cells (characters wide by lines high)
window-width = 160
window-height = 50

# Fix backspace key issues
term = xterm-256color

# Explicit keybindings for backspace to ensure it works correctly
keybind = backspace=text:\x7f
keybind = ctrl+backspace=text:\x08

cursor-style = block
cursor-style-blink = true
shell-integration-features = no-cursor
keybind = shift+enter=text:\n
