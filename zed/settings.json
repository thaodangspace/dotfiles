// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "allow_rewrap": "anywhere",
  "project_panel": {
    "dock": "left",
  },
  "language_models": {
    "openai_compatible": {
      "lms": {
        "api_url": "http://100.117.191.67:1234/v1",
        "available_models": [
          {
            "name": "qwen3.5-35b-a3b",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": true,
              "prompt_cache_key": false,
              "chat_completions": true
            }
          }
        ]
      },
      "llamacpp": {
        "api_url": "http://127.0.0.1:8080/v1",
        "available_models": [
          {
            "name": "qwen3.5-35b",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
    },
  },
  "redact_private_values": false,
  "use_system_path_prompts": false,
  "use_system_prompts": false,
  "confirm_quit": true,
  "disable_ai": false,
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "git_panel": {
    "tree_view": true,
    "dock": "right",
    "sort_by_path": true,
  },
  "ssh_connections": [
    {
      "host": "orb",
      "username": "dt",
      "args": [],
      "projects": [
        {
          "paths": ["/home/dt"],
        },
      ],
    },
    {
      "host": "fedora",
      "username": "dt",
      "args": [],
      "projects": [
        {
          "paths": ["/home/dt"],
        },
        {
          "paths": ["/home/dt/Code/self-hosted"],
        },
      ],
    },
  ],
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "ui_font_family": ".ZedMono",
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha - No Italics",
  },
  "relative_line_numbers": "enabled",
  "title_bar": {
    "show_user_picture": false,
  },
  "terminal": {
    "dock": "bottom",
    "font_family": "BlexMono Nerd Font Mono",
  },
  "vim_mode": true,
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "collaboration_panel": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "outline_panel": {
    "button": false,
  },
  "notification_panel": {
    "button": false,
  },
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "lmstudio",
      "model": "zeta",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "show_edit_predictions": true,
  "edit_predictions": {
    "mode": "eager",
    "provider": "open_ai_compatible_api",
    "open_ai_compatible_api": {
      "api_url": "http://100.111.225.41:1234/v1/completions",
      "model": "zeta",
      "prompt_format": "qwen",
      "max_output_tokens": 64,
    },
  },
  "languages": {
    "JavaScript": {
      "inlay_hints": {
        "enabled": true,
      },
      "formatter": "prettier",
      "format_on_save": "off",
    },
    "TypeScript": {
      "inlay_hints": {
        "enabled": true,
      },
      "formatter": "prettier",
    },
    "TSX": {
      "formatter": "prettier",
    },
    "JSON": {
      "formatter": "prettier",
    },
  },
  "prettier": {
    "allowed": true,
  },
  "format_on_save": "off",
}
