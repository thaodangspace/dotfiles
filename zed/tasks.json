[
  {
    "label": "lazygit",
    "command": "lazygit -p $ZED_WORKTREE_ROOT",
    "hide": "always",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "file_finder",
    "command": "zed \"$(tv files)\"",
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true
  },
  {
      "label": "live_grep",
      "command": "zed \"$(tv text --keybindings 'enter=\"confirm_selection\"')\"",
      "hide": "always",
      "allow_concurrent_runs": true,
      "use_new_terminal": true,
      "shell": {
        "program": "sh",
      },
  },
  {
      "label": "yazi",
      "command": "ya_zed $ZED_FILE",
      "hide": "always",
      "allow_concurrent_runs": true,
      "use_new_terminal": true
    }
]
